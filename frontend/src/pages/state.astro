---
import SiteHeader from "@/components/SiteHeader.astro";
import SiteLayout from "@/layouts/SiteLayout.astro";
import { orderDimensions, positioningEntrances } from "@/data/site";
---

<SiteLayout title="自我定位 | 复位" description="通过 3D 人生秩序地图，把状态碎片放回心理、认知、行动三大秩序里。">
  <SiteHeader />
  <main class="positioning-game-page">
    <section class="positioning-stage" aria-labelledby="positioning-title">
      <canvas id="order-map-canvas" class="order-map-canvas" aria-label="人生秩序 3D 地图"></canvas>

      <div class="positioning-overlay">
        <div class="positioning-intro">
          <p class="eyebrow">自我定位</p>
          <h1 id="positioning-title">把散落的状态碎片，放回你的人生秩序地图</h1>
          <p>
            你不用像填问卷一样分析自己。看到像你的碎片，就点一下。我们会慢慢看清：现在主要是心理不稳、认知不清，还是行动断裂。
          </p>
        </div>

        <aside class="map-panel map-panel-start" aria-label="开始定位">
          <div class="panel-heading">
            <h2>先选一个起点</h2>
            <p>凭直觉选就好。它不是最终结论，只是告诉我从哪里陪你开始。</p>
          </div>
          <div class="entry-stack" id="entry-stack">
            {positioningEntrances.map((entry) => (
              <button class="entry-button" type="button" data-entry={entry.value}>
                <span>{entry.direction}</span>
                <strong>{entry.label}</strong>
              </button>
            ))}
          </div>
        </aside>

        <div class="selected-order-banner" id="selected-order-banner" hidden>
          <div>
            <span>当前正在定位</span>
            <strong id="selected-order-title">心理秩序</strong>
            <p id="selected-order-copy">按住左键拖动旋转，滚动鼠标滚轮可以拉近或拉远。</p>
          </div>
          <button class="selected-order-back" type="button" id="reset-entry" aria-label="返回重新选择">
            <span aria-hidden="true">←</span>
            <em>重选</em>
          </button>
        </div>

        <aside class="map-panel map-panel-guide" aria-live="polite">
          <div class="panel-heading">
            <h2 id="guide-title">现在点一个状态碎片</h2>
            <p id="guide-copy">它们会漂浮在地图上。你不需要全部选择，先点最像你的几个。</p>
          </div>
          <div class="fragment-dock" id="fragment-dock" aria-label="已归位的状态碎片">
            <span class="dock-summary" id="selected-count">0 个碎片已归位</span>
            <div class="fragment-slots" id="fragment-slots"></div>
          </div>
          <button class="button button-secondary map-report-button" type="button" id="finish-positioning">
            <span class="report-button-core" aria-hidden="true"></span>
            <span class="report-button-text">
              <small>RESET CORE</small>
              <strong>生成复位报告</strong>
            </span>
          </button>
          <p class="report-gentle-hint" id="report-gentle-hint" aria-live="polite" hidden>再点满 3 个碎片，我就可以帮你生成报告哦。</p>
        </aside>
      </div>

      <div class="fragment-cloud" id="fragment-cloud" aria-label="状态碎片"></div>

      <section class="fragment-dialogue" id="fragment-dialogue" aria-live="polite" hidden>
        <span id="fragment-domain">状态碎片</span>
        <h2 id="fragment-title">这句话像不像你现在的状态？</h2>
        <p>不用证明，也不用解释。你只要选一个接近程度。</p>
        <div class="intensity-actions">
          <button type="button" data-intensity="1">有一点像</button>
          <button type="button" data-intensity="2">很像</button>
          <button type="button" data-intensity="3">几乎就是我</button>
        </div>
        <button class="quiet-button" type="button" id="skip-fragment">先放过这个</button>
      </section>

      <section class="report-progress-overlay" id="report-progress-overlay" aria-live="polite" hidden>
        <div class="report-progress-panel">
          <span>RESET ANALYSIS</span>
          <h2 id="report-progress-title">正在读取你的状态碎片</h2>
          <p id="report-progress-copy">我先把你放进凹槽的碎片放在一起看。</p>
          <div class="report-progress-track" aria-label="复位报告生成进度">
            <i id="report-progress-fill"></i>
          </div>
        </div>
      </section>
    </section>

    <section class="positioning-lab" aria-label="自定义状态碎片">
      <div class="section-heading">
        <p>Custom Fragment</p>
        <h2>如果有一句话没出现在地图里，你可以自己放进去</h2>
        <span>选择题优先，但你仍然可以用自己的话补充。你的表达不会丢掉。</span>
      </div>
      <div class="custom-fragment-panel">
        <label>
          你自己的状态碎片
          <input id="custom-fragment-text" placeholder="例如：我总觉得自己快要撑不住了，但又不知道该停在哪里" />
        </label>
        <label>
          你觉得它更靠近哪里
          <select id="custom-fragment-dimension">
            {orderDimensions.map((dimension) => (
              <option value={dimension.id}>{dimension.title}</option>
            ))}
          </select>
        </label>
        <label>
          接近程度
          <select id="custom-fragment-intensity">
            <option value="1">有一点像</option>
            <option value="2">很像</option>
            <option value="3">几乎就是我</option>
          </select>
        </label>
        <button class="button button-primary" type="button" id="add-custom-fragment">放进地图</button>
      </div>
    </section>

    <section class="positioning-report-section" aria-label="复位报告">
      <article class="tool-panel positioning-report" id="positioning-report" hidden>
        <div class="panel-heading">
          <h2>我先把你的地图整理成复位报告</h2>
          <p>这不是给你贴标签。它只是帮你看清：今天更应该先从哪里开始。</p>
        </div>
        <div class="result-box order-map" id="state-result"></div>
        <label>
          可选补充
          <textarea id="positioning-note" rows="3" placeholder="如果你想补一句现在最真实的感受，可以写在这里；说不清也可以留空。"></textarea>
        </label>
        <div class="dialogue-actions">
          <button class="button button-primary" type="button" id="save-positioning">保存并查看复位路径</button>
          <button class="button button-secondary" type="button" id="keep-positioning">我再选几个碎片</button>
        </div>
      </article>
    </section>

    <script is:inline type="application/json" id="order-dimensions-data" set:html={JSON.stringify(orderDimensions)}></script>
    <script is:inline type="application/json" id="positioning-entrances-data" set:html={JSON.stringify(positioningEntrances)}></script>
  </main>
</SiteLayout>

<script>
  // @ts-nocheck
  import * as THREE from "three";

  const storageKey = "resetlife:user-states";
  const pathKey = "resetlife:latest-path";
  const dimensions = JSON.parse(document.querySelector("#order-dimensions-data")?.textContent || "[]");
  const entrances = JSON.parse(document.querySelector("#positioning-entrances-data")?.textContent || "[]");

  const canvas = document.querySelector("#order-map-canvas");
  const gamePage = document.querySelector(".positioning-game-page");
  const stage = document.querySelector(".positioning-stage");
  const fragmentCloud = document.querySelector("#fragment-cloud");
  const dialogue = document.querySelector("#fragment-dialogue");
  const fragmentTitle = document.querySelector("#fragment-title");
  const fragmentDomain = document.querySelector("#fragment-domain");
  const guideTitle = document.querySelector("#guide-title");
  const guideCopy = document.querySelector("#guide-copy");
  const selectedCount = document.querySelector("#selected-count");
  const fragmentSlots = document.querySelector("#fragment-slots");
  const reportButton = document.querySelector("#finish-positioning");
  const reportHint = document.querySelector("#report-gentle-hint");
  const reportProgressOverlay = document.querySelector("#report-progress-overlay");
  const reportProgressTitle = document.querySelector("#report-progress-title");
  const reportProgressCopy = document.querySelector("#report-progress-copy");
  const reportProgressFill = document.querySelector("#report-progress-fill");
  const reportPanel = document.querySelector("#positioning-report");
  const positioningLab = document.querySelector(".positioning-lab");
  const resultBox = document.querySelector("#state-result");
  const selectedOrderBanner = document.querySelector("#selected-order-banner");
  const selectedOrderTitle = document.querySelector("#selected-order-title");
  const selectedOrderCopy = document.querySelector("#selected-order-copy");

  const state = {
    initialEntry: null,
    activeDimensionId: null,
    activeFragment: null,
    selected: [],
    scores: Object.fromEntries(dimensions.map((dimension) => [dimension.id, 0])),
  };
  let sceneController = null;
  let fragmentAnchors = [];
  let latestOrbitRotation = { x: 0, y: 0, z: 0 };
  let latestOrbitZoom = 1;
  let isGeneratingReport = false;
  const maxDockSlots = 3;

  const dimensionMeta = {
    psychology: { color: 0xd87563, position: [0, 0.08, 0], label: "心理秩序" },
    cognition: { color: 0x4d89c7, position: [0, 0.08, 0], label: "认知秩序" },
    action: { color: 0x45a878, position: [0, 0.08, 0], label: "行动秩序" },
  };

  const fragments = dimensions.flatMap((dimension) =>
    dimension.states.map((text, index) => ({
      id: `${dimension.id}-${index}`,
      text,
      dimensionId: dimension.id,
      dimensionTitle: dimension.title,
      repairTitle: dimension.repairTitle,
      shortTitle: dimension.shortTitle,
    })),
  );

  function escapeHtml(value) {
    return String(value).replace(/[&<>"']/g, (char) => ({
      "&": "&amp;",
      "<": "&lt;",
      ">": "&gt;",
      '"': "&quot;",
      "'": "&#039;",
    })[char]);
  }

  function readItems() {
    try {
      return JSON.parse(localStorage.getItem(storageKey) || "[]");
    } catch {
      return [];
    }
  }

  function writeItems(items) {
    localStorage.setItem(storageKey, JSON.stringify(items.slice(0, 20)));
  }

  function stableNoise(index, salt = 0) {
    const value = Math.sin((index + 1) * 12.9898 + salt * 78.233) * 43758.5453;
    return value - Math.floor(value);
  }

  function closeFragmentDialogue() {
    state.activeFragment = null;
    document.querySelectorAll(".floating-fragment").forEach((item) => item.classList.remove("is-active"));
    dialogue.hidden = true;
    renderFragmentSlots();
  }

  function projectFragmentPoint(anchor, rotation) {
    const cosY = Math.cos(rotation.y);
    const sinY = Math.sin(rotation.y);
    const cosX = Math.cos(rotation.x);
    const sinX = Math.sin(rotation.x);
    const cosZ = Math.cos(rotation.z);
    const sinZ = Math.sin(rotation.z);

    const yRotatedX = anchor.x * cosY + anchor.z * sinY;
    const yRotatedZ = -anchor.x * sinY + anchor.z * cosY;
    const xRotatedY = anchor.y * cosX - yRotatedZ * sinX;
    const xRotatedZ = anchor.y * sinX + yRotatedZ * cosX;

    return {
      x: yRotatedX * cosZ - xRotatedY * sinZ,
      y: yRotatedX * sinZ + xRotatedY * cosZ,
      z: xRotatedZ,
    };
  }

  function syncFragmentOrbit(rotation = latestOrbitRotation) {
    latestOrbitRotation = { x: rotation.x, y: rotation.y, z: rotation.z };
    fragmentCloud?.style.setProperty("--planet-zoom", latestOrbitZoom.toFixed(3));
    fragmentAnchors.forEach((anchor) => {
      if (!anchor.element) return;
      const point = projectFragmentPoint(anchor, latestOrbitRotation);
      const depth = Math.max(-240, Math.min(240, point.z));
      const projectedX = point.x * latestOrbitZoom;
      const projectedY = point.y * latestOrbitZoom;
      const scale = (0.9 + ((depth + 240) / 480) * 0.18) * Math.sqrt(latestOrbitZoom);
      const opacity = 0.78 + ((depth + 240) / 480) * 0.22;
      const distanceFromCenter = Math.hypot(projectedX, projectedY);
      const behindRatio = Math.max(0, Math.min(1, (-point.z - 16) / 130));
      const coverRatio = Math.max(0, Math.min(1, (188 * latestOrbitZoom - distanceFromCenter) / (86 * latestOrbitZoom)));
      const occlusion = behindRatio * coverRatio;
      const visibility = 1 - occlusion * 0.92;
      anchor.element.style.setProperty("--fragment-x", `${projectedX.toFixed(1)}px`);
      anchor.element.style.setProperty("--fragment-y", `${projectedY.toFixed(1)}px`);
      anchor.element.style.setProperty("--fragment-scale", scale.toFixed(3));
      anchor.element.style.setProperty("--fragment-opacity", opacity.toFixed(3));
      anchor.element.style.setProperty("--fragment-visibility", visibility.toFixed(3));
      anchor.element.style.setProperty("--fragment-blur", `${(occlusion * 2.4).toFixed(2)}px`);
      anchor.element.style.setProperty("--fragment-z", String(Math.round(20 + ((depth + 240) / 480) * 40)));
      anchor.element.classList.toggle("is-behind-planet", point.z < -16);
      anchor.element.classList.toggle("is-occluded-by-planet", occlusion > 0.45);
    });
  }

  function createPlanetSurface(baseColor, seed = 0) {
    const size = 512;
    const canvas = document.createElement("canvas");
    canvas.width = size;
    canvas.height = size;
    const ctx = canvas.getContext("2d");
    const color = new THREE.Color(baseColor);
    const r = Math.round(color.r * 255);
    const g = Math.round(color.g * 255);
    const b = Math.round(color.b * 255);

    const base = ctx.createLinearGradient(0, 0, size, size);
    base.addColorStop(0, `rgb(${Math.min(255, r + 58)}, ${Math.min(255, g + 48)}, ${Math.min(255, b + 42)})`);
    base.addColorStop(0.42, `rgb(${r}, ${g}, ${b})`);
    base.addColorStop(1, `rgb(${Math.max(0, r - 74)}, ${Math.max(0, g - 62)}, ${Math.max(0, b - 54)})`);
    ctx.fillStyle = base;
    ctx.fillRect(0, 0, size, size);

    for (let i = 0; i < 42; i += 1) {
      const y = stableNoise(i, seed + 0.13) * size;
      const height = 8 + stableNoise(i, seed + 0.37) * 28;
      const alpha = 0.035 + stableNoise(i, seed + 0.51) * 0.06;
      ctx.fillStyle = `rgba(255, 255, 252, ${alpha})`;
      ctx.beginPath();
      ctx.ellipse(size * 0.5, y, size * (0.52 + stableNoise(i, seed + 0.76) * 0.35), height, stableNoise(i, seed + 0.91) * 0.22 - 0.11, 0, Math.PI * 2);
      ctx.fill();
    }

    for (let i = 0; i < 1800; i += 1) {
      const x = stableNoise(i, seed + 1.7) * size;
      const y = stableNoise(i, seed + 2.9) * size;
      const radius = 0.35 + stableNoise(i, seed + 4.2) * 1.9;
      const light = stableNoise(i, seed + 5.4) > 0.52;
      ctx.fillStyle = light ? "rgba(255, 255, 252, 0.06)" : "rgba(0, 0, 0, 0.07)";
      ctx.beginPath();
      ctx.arc(x, y, radius, 0, Math.PI * 2);
      ctx.fill();
    }

    for (let i = 0; i < 22; i += 1) {
      const x = stableNoise(i, seed + 8.2) * size;
      const y = stableNoise(i, seed + 9.1) * size;
      const radius = 9 + stableNoise(i, seed + 10.3) * 30;
      const crater = ctx.createRadialGradient(x - radius * 0.28, y - radius * 0.24, 0, x, y, radius);
      crater.addColorStop(0, "rgba(255, 255, 252, 0.055)");
      crater.addColorStop(0.48, "rgba(0, 0, 0, 0.08)");
      crater.addColorStop(1, "rgba(0, 0, 0, 0)");
      ctx.fillStyle = crater;
      ctx.beginPath();
      ctx.arc(x, y, radius, 0, Math.PI * 2);
      ctx.fill();
    }

    const shade = ctx.createRadialGradient(size * 0.34, size * 0.28, 20, size * 0.52, size * 0.54, size * 0.7);
    shade.addColorStop(0, "rgba(255, 255, 252, 0.22)");
    shade.addColorStop(0.5, "rgba(255, 255, 252, 0)");
    shade.addColorStop(1, "rgba(0, 0, 0, 0.28)");
    ctx.fillStyle = shade;
    ctx.fillRect(0, 0, size, size);

    const map = new THREE.CanvasTexture(canvas);
    if ("SRGBColorSpace" in THREE) map.colorSpace = THREE.SRGBColorSpace;
    map.anisotropy = 8;
    map.needsUpdate = true;

    return map;
  }

  function createScene() {
    const scene = new THREE.Scene();
    const camera = new THREE.PerspectiveCamera(48, 1, 0.1, 100);
    const renderer = new THREE.WebGLRenderer({ canvas, alpha: true, antialias: true, preserveDrawingBuffer: true });
    renderer.setClearColor(0x111a2a, 0.28);
    const group = new THREE.Group();
    const spheres = new Map();
    let activeDimensionId = null;
    const baseTiltZ = -0.06;
    const baseCameraZ = 6.45;
    const minZoom = 0.72;
    const maxZoom = 2.35;
    const activeStartZoom = 1.45;
    let targetRotationX = 0;
    let targetRotationY = 0;
    let currentZoom = 1;
    let targetZoom = 1;
    let isDraggingOrder = false;
    let lastPointerX = 0;
    let lastPointerY = 0;

    scene.add(group);
    camera.position.set(0, 0, baseCameraZ);
    group.position.y = 0;
    group.rotation.z = baseTiltZ;
    latestOrbitRotation = { x: group.rotation.x, y: group.rotation.y, z: group.rotation.z };
    scene.add(new THREE.AmbientLight(0xffffff, 0.95));

    const keyLight = new THREE.DirectionalLight(0xffffff, 2.3);
    keyLight.position.set(4, 5, 6);
    scene.add(keyLight);

    const backLight = new THREE.PointLight(0x9fd6ff, 1.8, 18);
    backLight.position.set(-3, 1.5, 3);
    scene.add(backLight);

    dimensions.forEach((dimension) => {
      const meta = dimensionMeta[dimension.id];
      const surfaceMap = createPlanetSurface(meta.color, dimension.id.length);
      const sphere = new THREE.Mesh(
        new THREE.SphereGeometry(0.72, 64, 64),
        new THREE.MeshStandardMaterial({
          color: 0xffffff,
          map: surfaceMap,
          bumpMap: surfaceMap,
          bumpScale: 0.028,
          roughness: 0.82,
          metalness: 0,
          emissive: meta.color,
          emissiveIntensity: 0.018,
          transparent: true,
          opacity: 0.82,
        }),
      );
      sphere.position.set(...meta.position);
      sphere.scale.setScalar(0.01);
      sphere.material.opacity = 0;
      sphere.userData.targetScale = 0;
      group.add(sphere);

      const ring = new THREE.Mesh(
        new THREE.TorusGeometry(1.05, 0.008, 12, 112),
        new THREE.MeshBasicMaterial({ color: meta.color, transparent: true, opacity: 0.2 }),
      );
      ring.position.copy(sphere.position);
      ring.rotation.x = Math.PI / 2.7;
      ring.scale.setScalar(0.01);
      ring.material.opacity = 0;
      group.add(ring);

      const orbit = new THREE.Mesh(
        new THREE.TorusGeometry(1.36, 0.005, 8, 112),
        new THREE.MeshBasicMaterial({ color: 0xffffff, transparent: true, opacity: 0.08 }),
      );
      orbit.position.copy(sphere.position);
      orbit.rotation.x = Math.PI / 2.1;
      orbit.rotation.y = Math.PI / 8;
      orbit.scale.setScalar(0.01);
      orbit.material.opacity = 0;
      group.add(orbit);

      spheres.set(dimension.id, { sphere, ring, orbit });
    });

    const particleGeometry = new THREE.BufferGeometry();
    const particleCount = 170;
    const positions = new Float32Array(particleCount * 3);
    for (let i = 0; i < particleCount; i += 1) {
      positions[i * 3] = (Math.random() - 0.5) * 9;
      positions[i * 3 + 1] = (Math.random() - 0.5) * 4.6;
      positions[i * 3 + 2] = (Math.random() - 0.5) * 4;
    }
    particleGeometry.setAttribute("position", new THREE.BufferAttribute(positions, 3));
    const particles = new THREE.Points(
      particleGeometry,
      new THREE.PointsMaterial({ color: 0xffffff, size: 0.025, transparent: true, opacity: 0.5 }),
    );
    group.add(particles);

    sceneController = {
      setActiveDimension(nextDimensionId) {
        if (activeDimensionId !== nextDimensionId) {
          targetRotationX = 0;
          targetRotationY = 0;
          currentZoom = nextDimensionId ? activeStartZoom : 1;
          targetZoom = nextDimensionId ? activeStartZoom : 1;
          latestOrbitZoom = currentZoom;
          camera.position.z = baseCameraZ / currentZoom;
          fragmentCloud?.style.setProperty("--planet-zoom", currentZoom.toFixed(3));
        }
        activeDimensionId = nextDimensionId;
        spheres.forEach(({ sphere, ring, orbit }, id) => {
          const isActive = id === nextDimensionId;
          sphere.userData.targetScale = isActive ? 1 : 0;
          sphere.userData.targetOpacity = isActive ? 0.88 : 0;
          ring.userData.targetScale = isActive ? 1 : 0;
          ring.userData.targetOpacity = isActive ? 0.28 : 0;
          orbit.userData.targetScale = isActive ? 1 : 0;
          orbit.userData.targetOpacity = isActive ? 0.12 : 0;
        });
      },
      reset() {
        activeDimensionId = null;
        targetRotationX = 0;
        targetRotationY = 0;
        currentZoom = 1;
        targetZoom = 1;
        latestOrbitZoom = 1;
        camera.position.z = baseCameraZ;
        fragmentCloud?.style.setProperty("--planet-zoom", "1");
        this.setActiveDimension(null);
      },
    };

    function isInteractiveTarget(target) {
      return target instanceof HTMLElement && Boolean(target.closest("button, a, input, select, textarea, label"));
    }

    function startOrderDrag(event) {
      if (!activeDimensionId || event.button !== 0 || isInteractiveTarget(event.target)) return;
      isDraggingOrder = true;
      lastPointerX = event.clientX;
      lastPointerY = event.clientY;
      targetRotationX = group.rotation.x;
      targetRotationY = group.rotation.y;
      stage?.classList.add("is-dragging-order");
      closeFragmentDialogue();
      try {
        stage?.setPointerCapture?.(event.pointerId);
      } catch {
        // Some browsers only allow capture on the original pointer target.
      }
      event.preventDefault();
    }

    function dragOrder(event) {
      if (!isDraggingOrder) return;
      const dx = event.clientX - lastPointerX;
      const dy = event.clientY - lastPointerY;
      lastPointerX = event.clientX;
      lastPointerY = event.clientY;
      targetRotationY += dx * 0.0075;
      targetRotationX = Math.max(-0.82, Math.min(0.82, targetRotationX + dy * 0.005));
      event.preventDefault();
    }

    function stopOrderDrag(event) {
      if (!isDraggingOrder) return;
      isDraggingOrder = false;
      stage?.classList.remove("is-dragging-order");
      try {
        stage?.releasePointerCapture?.(event.pointerId);
      } catch {
        // Pointer capture may already be released when the pointer leaves the stage.
      }
    }

    function shouldIgnoreZoomTarget(target) {
      return target instanceof HTMLElement && Boolean(target.closest(".map-panel, .selected-order-banner, .fragment-dialogue, input, select, textarea, label"));
    }

    function zoomOrder(event) {
      if (!activeDimensionId || shouldIgnoreZoomTarget(event.target)) return;
      const delta = -event.deltaY * 0.00125;
      targetZoom = Math.max(minZoom, Math.min(maxZoom, targetZoom + delta));
      event.preventDefault();
    }

    function resize() {
      const rect = canvas.getBoundingClientRect();
      const width = Math.max(320, rect.width);
      const height = Math.max(420, rect.height);
      renderer.setPixelRatio(Math.min(window.devicePixelRatio || 1, 2));
      renderer.setSize(width, height, false);
      camera.aspect = width / height;
      camera.updateProjectionMatrix();
    }

    function animate() {
      const time = performance.now() * 0.001;
      group.rotation.x += (targetRotationX - group.rotation.x) * 0.06;
      group.rotation.y += (targetRotationY - group.rotation.y) * 0.06;
      group.rotation.z += (baseTiltZ - group.rotation.z) * 0.04;
      currentZoom += (targetZoom - currentZoom) * 0.12;
      latestOrbitZoom = currentZoom;
      camera.position.z += (baseCameraZ / currentZoom - camera.position.z) * 0.12;
      syncFragmentOrbit({ x: group.rotation.x, y: group.rotation.y, z: group.rotation.z });
      particles.rotation.y += 0.0007;

      spheres.forEach(({ sphere, ring, orbit }, id) => {
        const percent = getScorePercent(id) / 100;
        const targetScale = (sphere.userData.targetScale || 0) * (1 + percent * 0.2);
        sphere.scale.lerp(new THREE.Vector3(targetScale, targetScale, targetScale), 0.08);
        const ringScale = ring.userData.targetScale || 0;
        ring.scale.lerp(new THREE.Vector3(ringScale, ringScale, ringScale), 0.08);
        const orbitScale = orbit.userData.targetScale || 0;
        orbit.scale.lerp(new THREE.Vector3(orbitScale, orbitScale, orbitScale), 0.08);
        sphere.material.opacity += ((sphere.userData.targetOpacity || 0) - sphere.material.opacity) * 0.1;
        ring.material.opacity += ((ring.userData.targetOpacity || 0) - ring.material.opacity) * 0.1;
        orbit.material.opacity += ((orbit.userData.targetOpacity || 0) - orbit.material.opacity) * 0.1;
        sphere.material.emissiveIntensity = 0.018 + percent * 0.12;
        sphere.rotation.y += activeDimensionId === id ? 0.004 + percent * 0.005 : 0.001;
        sphere.rotation.x = Math.sin(time * 0.38) * 0.08;
        ring.rotation.z += 0.004 + percent * 0.004;
        orbit.rotation.z -= 0.002;
      });

      renderer.render(scene, camera);
      requestAnimationFrame(animate);
    }

    window.addEventListener("resize", resize);
    stage?.addEventListener("pointerdown", startOrderDrag);
    stage?.addEventListener("pointermove", dragOrder);
    stage?.addEventListener("pointerup", stopOrderDrag);
    stage?.addEventListener("pointercancel", stopOrderDrag);
    stage?.addEventListener("pointerleave", stopOrderDrag);
    stage?.addEventListener("wheel", zoomOrder, { passive: false });
    resize();
    animate();
  }

  function getScorePercent(dimensionId) {
    const dimension = dimensions.find((item) => item.id === dimensionId);
    const maxScore = Math.max(1, dimension.states.length * 3);
    return Math.min(100, Math.round(((state.scores[dimensionId] || 0) / maxScore) * 100));
  }

  function getDimensionScoreList() {
    return dimensions.map((dimension) => ({
      id: dimension.id,
      title: dimension.title,
      shortTitle: dimension.shortTitle,
      href: dimension.href,
      repairTitle: dimension.repairTitle,
      resultTitle: dimension.resultTitle,
      mechanism: dimension.mechanism,
      advice: dimension.advice,
      score: state.scores[dimension.id] || 0,
      maxScore: dimension.states.length * 3,
      percent: getScorePercent(dimension.id),
      selectedStates: state.selected
        .filter((item) => item.dimensionId === dimension.id)
        .map((item) => ({ state: item.text, intensity: item.intensity })),
    }));
  }

  function getConclusion(scores) {
    const sorted = [...scores].sort((a, b) => b.percent - a.percent);
    const [top, second, third] = sorted;
    const highCount = scores.filter((item) => item.percent >= 60).length;
    const totalScore = scores.reduce((sum, item) => sum + item.score, 0);

    if (totalScore === 0) {
      return {
        type: "暂时还看不清主导方向",
        title: "你的秩序结构还需要再多一点信息",
        dimensions: [],
        repairTitle: "继续自我定位",
        href: "/state/",
        mechanism: "你还没有把明显的状态碎片放进地图。我们可以先不急着下结论，再点几个最像你的碎片。",
        advice: "先选三到五个最像你的碎片就够了，不需要把全部状态都整理完。",
      };
    }

    if (highCount === 3) {
      return {
        type: "三系统混乱型",
        title: "你的当前状态：人生秩序整体失衡",
        dimensions: scores,
        repairTitle: "综合复位路径",
        href: "/path/#directions",
        mechanism: "心理、认知和行动都被明显影响时，不适合马上给自己安排复杂任务。我们先做最小复位，让系统先恢复一点稳定。",
        advice: "今天只做三件小事：暂停过度自责，选出最消耗你的压力源，再设计一个小到不会失败的行动。",
      };
    }

    if (top.percent - second.percent <= 10 && second.percent >= 35) {
      return {
        type: "双重混合型",
        title: `你的主要混乱源：${top.title} + ${second.title}`,
        dimensions: [top, second],
        repairTitle: top.repairTitle,
        href: top.href,
        mechanism: `现在最明显的是${top.title}和${second.title}一起影响你。我们先从更高的一项开始，不需要同时处理两条线。`,
        advice: top.advice,
      };
    }

    return {
      type: "单一主导型",
      title: `你的主要混乱源：${top.resultTitle}`,
      dimensions: [top],
      repairTitle: top.repairTitle,
      href: top.href,
      mechanism: top.mechanism,
      advice: top.advice,
      comparison: third ? `${top.shortTitle} ${top.percent}% · ${second.shortTitle} ${second.percent}% · ${third.shortTitle} ${third.percent}%` : "",
    };
  }

  function renderFragments() {
    if (!state.activeDimensionId) {
      fragmentCloud.innerHTML = "";
      fragmentAnchors = [];
      return;
    }
    const activeFragments = fragments.filter((fragment) => fragment.dimensionId === state.activeDimensionId);
    const count = Math.max(1, activeFragments.length);
    fragmentAnchors = activeFragments.map((fragment, index) => {
      const baseAngle = -Math.PI / 2 + (Math.PI * 2 * index) / count;
      const angle = baseAngle + (stableNoise(index, 1) - 0.5) * 0.14;
      const radius = 318 + (stableNoise(index, 2) - 0.5) * 28;
      return {
        fragmentId: fragment.id,
        x: Math.cos(angle) * radius,
        y: Math.sin(angle) * radius * 0.36 + (stableNoise(index, 3) - 0.5) * 12,
        z: Math.sin(angle) * radius * 0.42 + (stableNoise(index, 4) - 0.5) * 42,
        element: null,
      };
    });
    fragmentCloud.innerHTML = activeFragments
      .map((fragment, index) => {
        return `
          <button class="floating-fragment floating-fragment-${escapeHtml(fragment.dimensionId)}" type="button" data-fragment-id="${escapeHtml(fragment.id)}">
            ${escapeHtml(fragment.text)}
          </button>
        `;
      })
      .join("");
    fragmentAnchors.forEach((anchor) => {
      anchor.element = fragmentCloud.querySelector(`[data-fragment-id="${CSS.escape(anchor.fragmentId)}"]`);
    });
    syncFragmentOrbit();
  }

  function renderFragmentSlots() {
    if (!fragmentSlots) return;
    fragmentSlots.innerHTML = Array.from({ length: maxDockSlots })
      .map((_, index) => {
        const item = state.selected[index];
        const pendingItem = !item && state.activeFragment && index === state.selected.length ? state.activeFragment : null;
        if (pendingItem) {
          return `
            <div class="fragment-slot is-preview" data-slot="${index + 1}">
              <span class="slot-index">0${index + 1}</span>
              <button class="slot-fragment" type="button" data-tooltip="${escapeHtml(pendingItem.text)}" title="${escapeHtml(pendingItem.text)}">
                <strong>${escapeHtml(pendingItem.text)}</strong>
                <small>先放在这里，等你确认程度</small>
              </button>
            </div>
          `;
        }
        if (!item) {
          return `
            <div class="fragment-slot" data-slot="${index + 1}">
              <span class="slot-index">0${index + 1}</span>
              <span class="slot-placeholder">等一个像你的碎片</span>
            </div>
          `;
        }
        const intensityText = item.intensity === 3 ? "几乎就是我" : item.intensity === 2 ? "很像" : "有一点像";
        return `
          <div class="fragment-slot is-filled" data-slot="${index + 1}">
            <button class="slot-remove" type="button" data-remove-fragment="${escapeHtml(item.id)}" aria-label="删除这个碎片">×</button>
            <span class="slot-index">0${index + 1}</span>
            <button class="slot-fragment" type="button" data-tooltip="${escapeHtml(item.text)}" title="${escapeHtml(item.text)}">
              <strong>${escapeHtml(item.text)}</strong>
              <small>${escapeHtml(item.shortTitle || item.dimensionTitle)} · ${escapeHtml(intensityText)}</small>
            </button>
          </div>
        `;
      })
      .join("");
  }

  function updateSelectedOrderBanner() {
    if (!selectedOrderBanner) return;
    if (!state.activeDimensionId || !state.initialEntry) {
      selectedOrderBanner.hidden = true;
      return;
    }
    const dimension = dimensions.find((item) => item.id === state.activeDimensionId);
    selectedOrderTitle.textContent = dimension?.title || state.initialEntry.direction || "当前秩序";
    selectedOrderCopy.textContent = "按住左键拖动旋转，滚动鼠标滚轮可以拉近或拉远。";
    selectedOrderBanner.hidden = false;
  }

  function updateGuide() {
    selectedCount.textContent = `${state.selected.length} 个碎片已归位`;
    renderFragmentSlots();
    reportButton?.classList.toggle("is-ready", state.selected.length >= maxDockSlots);
    reportButton?.classList.remove("needs-more-fragments");
    if (reportHint instanceof HTMLElement && state.selected.length >= maxDockSlots) reportHint.hidden = true;
    if (!state.initialEntry) {
      stage?.classList.remove("has-started");
      stage?.removeAttribute("data-active-dimension");
      updateSelectedOrderBanner();
      guideTitle.textContent = "先选一个起点";
      guideCopy.textContent = "选完起点后，再点地图上的状态碎片。";
      return;
    }
    stage?.classList.add("has-started");
    stage?.setAttribute("data-active-dimension", state.activeDimensionId || "");
    updateSelectedOrderBanner();
    guideTitle.textContent = state.selected.length ? "把最像你的碎片放进凹槽" : "现在点一个状态碎片";
    guideCopy.textContent =
      state.selected.length >= maxDockSlots
        ? "三个凹槽已经放满了。你可以生成报告，也可以删掉一个再换。"
        : "先放进三个最像你的。鼠标停在凹槽上，可以看完整描述。";
  }

  function resetEntrySelection() {
    resetReportProgress();
    gamePage?.classList.remove("is-reporting");
    if (stage instanceof HTMLElement) stage.hidden = false;
    state.initialEntry = null;
    state.activeDimensionId = null;
    state.activeFragment = null;
    state.selected = [];
    state.scores = Object.fromEntries(dimensions.map((dimension) => [dimension.id, 0]));
    sceneController?.reset();
    fragmentCloud.innerHTML = "";
    fragmentAnchors = [];
    dialogue.hidden = true;
    if (positioningLab instanceof HTMLElement) positioningLab.hidden = false;
    reportPanel.hidden = true;
    document.querySelectorAll(".entry-button").forEach((item) => item.classList.remove("is-selected"));
    document.querySelectorAll(".floating-fragment").forEach((item) => item.classList.remove("is-active", "is-collected"));
    document.querySelector(".map-panel-start")?.classList.remove("is-compact");
    updateGuide();
  }

  function placeDialogue(anchor) {
    if (!(anchor instanceof HTMLElement)) return;
    const anchorRect = anchor.getBoundingClientRect();
    const width = Math.min(460, window.innerWidth - 32);
    const estimatedHeight = 250;
    let left = anchorRect.right + 14;
    let top = anchorRect.top - 12;

    if (left + width > window.innerWidth - 16) {
      left = anchorRect.left - width - 14;
    }

    if (left < 16) {
      left = Math.min(window.innerWidth - width - 16, anchorRect.left);
    }

    if (top < 82) {
      top = 82;
    }

    if (top + estimatedHeight > window.innerHeight - 16) {
      top = Math.max(16, window.innerHeight - estimatedHeight - 16);
    }

    dialogue.style.setProperty("--dialogue-left", `${Math.round(left)}px`);
    dialogue.style.setProperty("--dialogue-top", `${Math.round(top)}px`);
    dialogue.style.setProperty("--dialogue-width", `${Math.round(width)}px`);
  }

  function openFragment(fragment, anchor) {
    state.activeFragment = fragment;
    document.querySelectorAll(".floating-fragment").forEach((item) => item.classList.remove("is-active"));
    anchor?.classList.add("is-active");
    fragmentTitle.textContent = fragment.text;
    fragmentDomain.textContent = fragment.dimensionTitle;
    placeDialogue(anchor);
    dialogue.hidden = false;
    renderFragmentSlots();
  }

  function chooseIntensity(intensity) {
    if (!state.activeFragment) return;
    const fragment = state.activeFragment;
    if (!state.selected.some((item) => item.id === fragment.id) && state.selected.length < maxDockSlots) {
      state.selected.push({ ...fragment, intensity });
      state.scores[fragment.dimensionId] = (state.scores[fragment.dimensionId] || 0) + intensity;
      document.querySelector(`[data-fragment-id="${CSS.escape(fragment.id)}"]`)?.classList.add("is-collected");
    }
    state.activeFragment = null;
    document.querySelectorAll(".floating-fragment").forEach((item) => item.classList.remove("is-active"));
    dialogue.hidden = true;
    updateGuide();
  }

  function removeSelectedFragment(fragmentId) {
    const selectedIndex = state.selected.findIndex((item) => item.id === fragmentId);
    if (selectedIndex < 0) return;
    const [removed] = state.selected.splice(selectedIndex, 1);
    state.scores[removed.dimensionId] = Math.max(0, (state.scores[removed.dimensionId] || 0) - removed.intensity);
    document.querySelector(`[data-fragment-id="${CSS.escape(removed.id)}"]`)?.classList.remove("is-collected", "is-active");
    if (state.activeFragment?.id === removed.id) {
      state.activeFragment = null;
      dialogue.hidden = true;
    }
    updateGuide();
  }

  function renderBars(scores) {
    return scores
      .map(
        (item) => `
          <div class="order-bar">
            <span>${escapeHtml(item.title)}</span>
            <strong>${escapeHtml(item.percent)}%</strong>
            <i style="--value: ${escapeHtml(item.percent)}%"></i>
          </div>
        `,
      )
      .join("");
  }

  function renderSelectedStates(scores) {
    const selected = scores.flatMap((item) =>
      item.selectedStates.slice(0, 4).map((selectedState) => `${item.shortTitle}：${selectedState.state}`),
    );
    if (!selected.length) return "<p>你还没有选择明显状态，我们可以再点几个碎片。</p>";
    return `<p>你放进地图的状态碎片：${selected.map(escapeHtml).join(" / ")}</p>`;
  }

  function buildDraft() {
    const scores = getDimensionScoreList();
    const conclusion = getConclusion(scores);
    const note = String(document.querySelector("#positioning-note")?.value || "").trim();
    return {
      initialEntry: state.initialEntry || { value: "custom", label: "暂未选择", direction: "你自己的描述" },
      scores,
      conclusion,
      note,
      date: new Date().toLocaleString("zh-CN", { hour12: false }),
    };
  }

  function resetReportProgress() {
    isGeneratingReport = false;
    if (reportProgressOverlay instanceof HTMLElement) reportProgressOverlay.hidden = true;
    if (reportProgressFill instanceof HTMLElement) reportProgressFill.style.width = "0%";
    reportButton?.removeAttribute("disabled");
    stage?.classList.remove("is-generating-report");
  }

  function startReportProgress(onComplete) {
    if (isGeneratingReport) return;
    isGeneratingReport = true;
    closeFragmentDialogue();
    reportButton?.setAttribute("disabled", "true");
    stage?.classList.add("is-generating-report");
    if (reportProgressOverlay instanceof HTMLElement) reportProgressOverlay.hidden = false;

    const steps = [
      { at: 0, title: "正在读取你的状态碎片", copy: "我先把你放进凹槽的碎片放在一起看。" },
      { at: 34, title: "正在整理主要失序来源", copy: "我会看见哪一类秩序正在消耗你更多力气。" },
      { at: 68, title: "正在生成复位建议", copy: "我会把结果说得清楚一点，让下一步更容易开始。" },
      { at: 96, title: "报告即将完成", copy: "马上给你一份可以继续行动的复位报告。" },
    ];
    const duration = 1750;
    const startedAt = performance.now();
    let activeStepIndex = -1;

    function tick(now) {
      const progress = Math.min(100, ((now - startedAt) / duration) * 100);
      if (reportProgressFill instanceof HTMLElement) reportProgressFill.style.width = `${progress.toFixed(1)}%`;

      const nextStepIndex = steps.reduce((latest, step, index) => (progress >= step.at ? index : latest), 0);
      if (nextStepIndex !== activeStepIndex) {
        activeStepIndex = nextStepIndex;
        if (reportProgressTitle) reportProgressTitle.textContent = steps[nextStepIndex].title;
        if (reportProgressCopy) reportProgressCopy.textContent = steps[nextStepIndex].copy;
      }

      if (progress < 100) {
        requestAnimationFrame(tick);
        return;
      }

      window.setTimeout(onComplete, 260);
    }

    requestAnimationFrame(tick);
  }

  function showReport(draft) {
    if (state.selected.length < maxDockSlots) {
      const remaining = maxDockSlots - state.selected.length;
      if (reportHint instanceof HTMLElement) {
        reportHint.textContent = `再放进 ${remaining} 个最像你的碎片，我就可以帮你生成报告哦。`;
        reportHint.hidden = false;
      }
      reportButton?.classList.remove("needs-more-fragments");
      requestAnimationFrame(() => reportButton?.classList.add("needs-more-fragments"));
      return;
    }
    if (reportHint instanceof HTMLElement) reportHint.hidden = true;
    resultBox.innerHTML = `
      <strong>${escapeHtml(draft.conclusion.title)}</strong>
      <div class="order-bars">${renderBars(draft.scores)}</div>
      <p>一开始你更像：${escapeHtml(draft.initialEntry.label || "暂未选择")}</p>
      ${renderSelectedStates(draft.scores)}
      <p>${escapeHtml(draft.conclusion.mechanism)}</p>
      <p>${escapeHtml(draft.conclusion.advice)}</p>
      <p>下一步建议：${escapeHtml(draft.conclusion.repairTitle)}</p>
    `;
    resetReportProgress();
    if (positioningLab instanceof HTMLElement) positioningLab.hidden = true;
    if (stage instanceof HTMLElement) stage.hidden = true;
    gamePage?.classList.add("is-reporting");
    reportPanel.hidden = false;
    requestAnimationFrame(() => {
      reportPanel.scrollIntoView({ behavior: "smooth", block: "start" });
    });
  }

  function renderReport() {
    if (state.selected.length < maxDockSlots) {
      showReport(null);
      return;
    }
    if (isGeneratingReport) return;
    if (reportHint instanceof HTMLElement) reportHint.hidden = true;
    const draft = buildDraft();
    startReportProgress(() => showReport(draft));
  }

  function addCustomFragment() {
    if (state.selected.length >= maxDockSlots) return;
    const textInput = document.querySelector("#custom-fragment-text");
    const dimensionSelect = document.querySelector("#custom-fragment-dimension");
    const intensitySelect = document.querySelector("#custom-fragment-intensity");
    const text = String(textInput?.value || "").trim();
    if (!text) return;
    const dimension = dimensions.find((item) => item.id === dimensionSelect?.value) || dimensions[0];
    const intensity = Number(intensitySelect?.value || 1);
    state.selected.push({
      id: `custom-${Date.now()}`,
      text,
      dimensionId: dimension.id,
      dimensionTitle: dimension.title,
      repairTitle: dimension.repairTitle,
      shortTitle: dimension.shortTitle,
      intensity,
    });
    state.scores[dimension.id] = (state.scores[dimension.id] || 0) + intensity;
    textInput.value = "";
    updateGuide();
  }

  function saveAndContinue() {
    const draft = buildDraft();
    writeItems([draft, ...readItems()]);
    localStorage.setItem(
      pathKey,
      JSON.stringify({
        ...draft,
        direction: {
          title: draft.conclusion.repairTitle,
          href: draft.conclusion.href,
          reason: draft.conclusion.advice,
        },
        states: draft.scores.flatMap((item) => item.selectedStates.map((selectedState) => selectedState.state)),
        lifeArea: draft.conclusion.title,
        stage: "自我定位完成",
      }),
    );
    window.location.href = "/path/";
  }

  document.querySelector("#entry-stack")?.addEventListener("click", (event) => {
    const button = event.target instanceof HTMLElement ? event.target.closest("[data-entry]") : null;
    if (!button) return;
    const entry = entrances.find((item) => item.value === button.getAttribute("data-entry"));
    state.initialEntry = entry;
    state.activeDimensionId = entry?.value || null;
    sceneController?.setActiveDimension(state.activeDimensionId);
    document.querySelectorAll(".entry-button").forEach((item) => item.classList.toggle("is-selected", item === button));
    document.querySelector(".map-panel-start")?.classList.add("is-compact");
    renderFragments();
    updateGuide();
  });

  fragmentCloud.addEventListener("click", (event) => {
    const button = event.target instanceof HTMLElement ? event.target.closest("[data-fragment-id]") : null;
    if (!button || button.classList.contains("is-collected")) return;
    if (state.selected.length >= maxDockSlots) return;
    const fragment = fragments.find((item) => item.id === button.getAttribute("data-fragment-id"));
    if (fragment) openFragment(fragment, button);
  });

  fragmentSlots?.addEventListener("click", (event) => {
    const button = event.target instanceof HTMLElement ? event.target.closest("[data-remove-fragment]") : null;
    const fragmentId = button?.getAttribute("data-remove-fragment");
    if (fragmentId) removeSelectedFragment(fragmentId);
  });

  dialogue.addEventListener("click", (event) => {
    const target = event.target;
    if (!(target instanceof HTMLElement)) return;
    const intensity = target.getAttribute("data-intensity");
    if (intensity) chooseIntensity(Number(intensity));
  });

  document.querySelector("#skip-fragment")?.addEventListener("click", () => {
    state.activeFragment = null;
    document.querySelectorAll(".floating-fragment").forEach((item) => item.classList.remove("is-active"));
    dialogue.hidden = true;
    renderFragmentSlots();
  });
  document.querySelector("#reset-entry")?.addEventListener("click", resetEntrySelection);
  document.querySelector("#finish-positioning")?.addEventListener("click", renderReport);
  document.querySelector("#add-custom-fragment")?.addEventListener("click", addCustomFragment);
  document.querySelector("#save-positioning")?.addEventListener("click", saveAndContinue);
  document.querySelector("#keep-positioning")?.addEventListener("click", () => {
    resetReportProgress();
    reportPanel.hidden = true;
    gamePage?.classList.remove("is-reporting");
    if (stage instanceof HTMLElement) stage.hidden = false;
    if (positioningLab instanceof HTMLElement) positioningLab.hidden = false;
    document.querySelector(".positioning-stage")?.scrollIntoView({ behavior: "smooth", block: "start" });
  });

  function selectFromQuery() {
    const selectedEntry = new URLSearchParams(window.location.search).get("entry");
    if (!selectedEntry) return;
    const button = document.querySelector(`[data-entry="${CSS.escape(selectedEntry)}"]`);
    if (button instanceof HTMLButtonElement) button.click();
  }

  createScene();
  renderFragments();
  selectFromQuery();
  updateGuide();
</script>
