---
import SiteFooter from "@/components/SiteFooter.astro";
import SiteHeader from "@/components/SiteHeader.astro";
import SiteLayout from "@/layouts/SiteLayout.astro";
import { cognitionItems, projects, techItems } from "@/data/site";
---

<SiteLayout title="Hangge | 认知、技术与项目" description="Hangge 的个人 Web 站点，沉淀认知、技术实践和个人项目。">
  <SiteHeader />
  <main>
    <section class="hero">
      <div class="hero-inner">
        <p class="pill">认知 · 技术 · 项目</p>
        <h1>Hangge</h1>
        <p class="hero-copy">
          这里会逐步沉淀我的思考、工程实践和个人项目。跑步瘦身助手会保留为项目板块中的一个独立应用。
        </p>
        <div class="actions">
          <a class="button button-primary" href="#projects">查看项目</a>
          <a class="button button-secondary" href="/app/slimming/">进入跑步助手</a>
        </div>
      </div>
    </section>

    <section id="cognition" class="section">
      <div class="section-heading">
        <p>Cognition</p>
        <h2>认知板块</h2>
        <span>沉淀长期思考、方法论和复盘记录，把模糊想法整理成可复用的判断框架。</span>
      </div>
      <div class="card-grid">
        {cognitionItems.map((item) => (
          <article class="card">
            <h3>{item.title}</h3>
            <p>{item.description}</p>
          </article>
        ))}
      </div>
    </section>

    <section id="tech" class="section section-muted">
      <div class="section-heading">
        <p>Technology</p>
        <h2>技术板块</h2>
        <span>记录前端、后端、部署和 AI 辅助开发中的实际经验，优先保留能复用的工程结论。</span>
      </div>
      <div class="tech-grid">
        {techItems.map((item) => <div class="tech-item">{item}</div>)}
      </div>
    </section>

    <section id="projects" class="section">
      <div class="section-heading">
        <p>Projects</p>
        <h2>项目板块</h2>
        <span>把想法做成可运行的工具。每个项目都会记录问题、方案、技术栈和后续计划。</span>
      </div>
      <div class="project-list">
        {projects.map((project) => (
          <a class="project-card" href={project.href}>
            <img class="project-card-image" src={project.image} alt={`${project.title} 预览`} loading="lazy" />
            <div>
              <span class="pill">{project.status}</span>
              <h3>{project.title}</h3>
              <p>{project.description}</p>
            </div>
            <span class="button button-primary">查看项目</span>
          </a>
        ))}
      </div>
    </section>
  </main>
  <SiteFooter />
</SiteLayout>
