new file mode 100644
index 0000000..eb1b486
--- /dev/null
+++ b/app/globals.css
@@ -0,0 +1,85 @@
+@import "tailwindcss";
+
+:root {
+  --surface-base: #f7f8fa;
+  --surface-panel: #ffffff;
+  --surface-subtle: #eef2f5;
+  --ink-primary: #18212a;
+  --ink-secondary: #5f6b76;
+  --ink-muted: #8b96a1;
+  --border-soft: #dde4ea;
+  --primary: #2563eb;
+  --primary-foreground: #ffffff;
+  --health: #10b981;
+  --health-soft: #dff8ec;
+  --motion: #0ea5e9;
+  --motion-soft: #e0f2fe;
+  --warning: #f59e0b;
+  --warning-soft: #fef3c7;
+  --danger: #dc2626;
+  --danger-soft: #fee2e2;
+}
+
+* {
+  box-sizing: border-box;
+}
+
+html {
+  background: var(--surface-base);
+  color: var(--ink-primary);
+}
+
+body {
+  margin: 0;
+  min-height: 100vh;
+  background: var(--surface-base);
+  color: var(--ink-primary);
+  font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
+  font-size: 14px;
+  line-height: 1.55;
+  letter-spacing: 0;
+}
+
+a {
+  color: inherit;
+  text-decoration: none;
+}
+
+button,
+a {
+  -webkit-tap-highlight-color: transparent;
+}
+
+:focus-visible {
+  outline: 2px solid var(--primary);
+  outline-offset: 2px;
+}
+
+.app-shell {
+  min-height: 100vh;
+  display: grid;
+  grid-template-columns: 220px minmax(0, 1fr);
+}
+
+.page-main {
+  width: 100%;
+  max-width: 1200px;
+  padding: 24px;
+}
+
+.card {
+  background: var(--surface-panel);
+  border: 1px solid var(--border-soft);
+  border-radius: 8px;
+}
+
+@media (max-width: 767px) {
+  .app-shell {
+    display: block;
+    padding-bottom: 72px;
+  }
+
+  .page-main {
+    padding: 16px;
+  }
+}
