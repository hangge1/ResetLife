+import { AppShell } from "@/components/layout/app-shell";
+import { Button } from "@/components/ui/button";
+import { StatusCard } from "@/features/dashboard/components/status-card";
+
+const statusItems = [
+  { label: "身体数据", value: "待记录", tone: "warning" },
+  { label: "跑步记录", value: "待添加", tone: "motion" },
+  { label: "提醒状态", value: "未开启提醒", tone: "neutral" },
+];
+
+const metricCards = [
+  {
+    title: "健康摘要",
+    value: "暂无数据",
+    description: "记录体重、围度和体脂率后显示趋势。",
+    tone: "health",
+  },
+  {
+    title: "运动摘要",
+    value: "暂无跑量",
+    description: "添加跑步记录后显示本周跑量和次数。",
+    tone: "motion",
+  },
+  {
+    title: "目标进度",
+    value: "未设置",
+    description: "设置健康目标和跑步目标后显示差距。",
+    tone: "warning",
+  },
+] as const;
+
+export default function Home() {
+  return (
+    <AppShell>
+      <main className="page-main">
+        <div className="mb-5 flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
+          <div>
+            <h1 className="m-0 text-[32px] font-semibold leading-tight tracking-normal text-[var(--ink-primary)]">
+              瘦身助手
+            </h1>
+            <p className="mt-2 max-w-2xl text-sm text-[var(--ink-secondary)]">
+              今天先完成记录，再看趋势和目标差距。
+            </p>
+          </div>
+          <Button>记录今天</Button>
+        </div>
+
+        <section aria-labelledby="today-status" className="card mb-4 p-4">
+          <div className="mb-3 flex items-center justify-between gap-3">
+            <h2 id="today-status" className="m-0 text-base font-semibold">
+              今日状态
+            </h2>
+            <span className="rounded-full bg-[var(--warning-soft)] px-3 py-1 text-xs font-semibold text-[#92400e]">
+              待开始
+            </span>
+          </div>
+          <div className="grid gap-2">
+            {statusItems.map((item) => (
+              <div
+                key={item.label}
+                className="flex min-h-11 items-center justify-between border-b border-[var(--border-soft)] py-2 last:border-b-0"
+              >
+                <span className="text-[var(--ink-secondary)]">{item.label}</span>
+                <span className="font-semibold text-[var(--ink-primary)]">{item.value}</span>
+              </div>
+            ))}
+          </div>
+        </section>
+
+        <section
+          aria-label="首页摘要"
+          className="grid grid-cols-1 gap-4 md:grid-cols-3"
+        >
+          {metricCards.map((card) => (
+            <StatusCard key={card.title} {...card} />
+          ))}
+        </section>
+      </main>
+    </AppShell>
+  );
+}
