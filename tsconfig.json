{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noEmit": true,
    "resolveJsonModule": true,
    "allowJs": true,
    "checkJs": false,
    "types": [
      "node"
    ]
  },
  "include": [
    "scripts/**/*.mjs",
    "tests/**/*.mjs"
  ],
  "exclude": [
    "dist",
    "node_modules",
    "web/dist",
    "web/node_modules"
  ]
}
